  /* ===== Records ===== */
  const REC_KEY="ppk_records_v2";
  function loadRecords(){
    try{
      const raw=localStorage.getItem(REC_KEY);
      if(!raw) return [];
      const arr=JSON.parse(raw);
      return Array.isArray(arr)?arr:[];
    }catch{return [];}
  }
  function saveRecords(records){
    localStorage.setItem(REC_KEY,JSON.stringify(records));
  }
  function resultLabel(result){
    if(result==="win")return"通關";
    if(result==="timeout")return"超時失敗";
    if(result==="wrong")return"答錯失敗";
    return"—";
  }
  function addRecord(record){
    const records=loadRecords();
    records.unshift(record);
    saveRecords(records.slice(0,50));
  }
  function formatTimesForTable(r){
    const out=[];
    for(let i=0;i<3;i++){
      const idx=i+1;
      if(i<(r.times?.length||0)){
        out.push(`第${idx}回合：${r.times[i]}s`);
        continue;
      }
      if(r.result==="timeout" && r.failRound===idx){
        out.push(`第${idx}回合：超時`);
        continue;
      }
      if(r.result==="wrong" && r.failRound===idx){
        out.push(`第${idx}回合：答錯`);
        continue;
      }
      out.push(`第${idx}回合：—`);
    }
    return out.join("<br/>");
  }
