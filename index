    const records=loadRecords();
    if(records.length===0){
      return `<div style="color:rgba(55,65,81,.90); font-weight:900;">目前沒有紀錄。</div>`;
    }
    const rows=records.map(r=>{
      const diffName=DIFF[r.diffKey]?.name ?? r.diffKey;
      const tagClass=r.diffKey==="easy"?"easy":(r.diffKey==="mid"?"mid":"hard");
