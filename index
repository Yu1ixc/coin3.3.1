  function clamp(n,a,b){return Math.max(a,Math.min(b,n));}
  function applyAutoScale(){
    document.documentElement.style.setProperty("--ui-scale","1");
    requestAnimationFrame(()=>{
      const doc=document.documentElement;
      const body=document.body;
      const viewportH=window.innerHeight||doc.clientHeight;
      const contentH=Math.max(body.scrollHeight,doc.scrollHeight);
      if(contentH<=viewportH+1){
        document.documentElement.style.setProperty("--ui-scale","1");
        return;
      }
      const ratio=viewportH/contentH;
      const scale=clamp(ratio*0.99,0.75,1);
      document.documentElement.style.setProperty("--ui-scale",String(scale));
    });
  }
  window.addEventListener("resize",applyAutoScale);
  window.addEventListener("orientationchange",applyAutoScale);
  function nudgeScaleSoon(){requestAnimationFrame(applyAutoScale); setTimeout(applyAutoScale,50);}
  applyAutoScale();

  const pad2 = n => String(n).padStart(2,"0");
  function nowLocalString(){
    const d=new Date();
    return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())} ${pad2(d.getHours())}:${pad2(d.getMinutes())}:${pad2(d.getSeconds())}`;
  }
  function showToast(msg,ms=900){
    toastEl.textContent=msg;
    toastEl.classList.add("show");
    clearTimeout(showToast._t);
    showToast._t=setTimeout(()=>toastEl.classList.remove("show"),ms);
  }
  function openModal({title,bodyHTML,actions=[],showClose=false,lock=false}){
    modalLocked=!!lock;
    modalTitle.textContent=title;
