  function formatTimesForEndModal(result){
    const out=[];
    for(let i=0;i<3;i++){
      const idx=i+1;
      if(i<gameState.perRoundTimes.length){
        out.push(`<div>第${idx}回合：<strong>${gameState.perRoundTimes[i]}s</strong></div>`);
        continue;
      }
      if(result==="timeout" && (gameState.roundIndex+1)===idx){
        out.push(`<div>第${idx}回合：<strong>超時</strong></div>`);
        continue;
      }
      if(result==="wrong" && (gameState.roundIndex+1)===idx){
        out.push(`<div>第${idx}回合：<strong>答錯</strong></div>`);
        continue;
      }
      out.push(`<div>第${idx}回合：<span style="color:rgba(148,163,184,.9);">—</span></div>`);
    }
    return out.join("");
  }

  function endGame(win,endType,reasonText){
    stopTimer();
    clearTapSelection();
    if(!gameState.inGame)return;
    gameState.inGame=false;

    const title=win?"通關成功":"遊戲結束";

    if(!skipRecordThisGame){
      const record={
        diffKey:gameState.diffKey,
        times:[...gameState.perRoundTimes],
        playedAt:nowLocalString(),
        result:win?"win":endType,
        failRound:win?null:(gameState.roundIndex+1)
      };
      addRecord(record);
    }

    const showCards=!win;
    const body=`
      <div>
        ${reasonText?`<div style="margin-bottom:12px;">${reasonText}</div>`:""}
        <div><span style="color:rgba(75,85,99,.95); font-weight:900;">難度：</span><strong>${DIFF[gameState.diffKey].name}</strong></div>
        <div style="margin-top:10px;">
          <span style="color:rgba(75,85,99,.95); font-weight:900;">這局結果：</span>
          <strong>${resultLabel(win?"win":endType)}</strong>
        </div>
        <div style="margin-top:10px;">
          <span style="color:rgba(75,85,99,.95); font-weight:900;">每回合用時：</span>
          <div style="margin-top:8px;">
            ${formatTimesForEndModal(win?"win":endType)}
          </div>
        </div>
        ${showCards
          ? buildResultCardsHTML(gameState.roundGoal,gameState.digits,gameState.lastAnswerDigits)
          : ""}
      </div>
    `;

    if(endType==="timeout"){
      timeoutEndState={title,bodyHTML:body};
      showTimeoutEndSummary();
      return;
    }

    openModal({
      title,
      bodyHTML:body,
      actions:[
        {label:"回到主畫面",primary:true,onClick:()=>{forceCloseModal(); switchScreen(false);}},
        {label:"查看紀錄",onClick:()=>{forceCloseModal(); showRecordsModalStandalone();}}
      ],
      showClose:false,
      lock:false
    });
  }

  function submitAnswer(){
    if(!gameState.inGame)return;
    const ans=readAnswerString();
    if(ans==null){
      showToast("作答欄還沒放滿四張牌");
      return;
    }
    const correct=computeAnswer(gameState.roundGoal,gameState.digits);
    stopTimer();

    const elapsedSec=Math.round((performance.now()-gameState.startTs)/1000);
    gameState.perRoundTimes.push(elapsedSec);

    if(ans===correct){
      if(gameState.roundIndex===2){
        endGame(true,"win","三個回合皆為正確答案。");
      }else{
        showToast("答案正確，進入下一回合",900);
        gameState.roundIndex+=1;
        setupRound();
        startRoundCountdownTimer();
      }
    }else{
      endGame(false,"wrong",`答案不正確。排出的數字為 <strong>${ans}</strong>，正確答案為 <strong>${correct}</strong>。`);
    }
  }

  function leaveGame(){
    skipRecordThisGame=true;
    stopTimer();
    clearTapSelection();
    countdownOverlay.classList.remove("show");
    forceCloseModal();
    gameState.inGame=false;
    switchScreen(false);
  }

  /* ==== Events ==== */
  diffBtns.forEach(btn=>{
    btn.addEventListener("click",()=>{
      diffBtns.forEach(b=>b.classList.remove("selected"));
      btn.classList.add("selected");
      selectedDiff=btn.dataset.diff;
      startGameBtn.disabled=false;
      nudgeScaleSoon();
    });
  });

  startGameBtn.addEventListener("click",()=>{
    if(!selectedDiff)return;
    gameState.diffKey=selectedDiff;
    startGame();
  });

  helpBtnHome.addEventListener("click",()=>openHelp(0));
  /* 遊戲中開啟說明時，預設從「上方題目與狀態欄」開始 */
  helpBtnGame.addEventListener("click",()=>openHelp(3));

  recordsBtnHome.addEventListener("click",showRecordsModalStandalone);
  recordsBtnGame.addEventListener("click",showRecordsModalStandalone);

  leaveBtnGame.addEventListener("click",()=>{
    openModal({
      title:"離開遊戲",
      bodyHTML:`<div>確定要離開遊戲並回到主畫面嗎？<br/><span style="color:rgba(75,85,99,.95); font-weight:900;">這一局將不會記錄成績。</span></div>`,
      actions:[
        {label:"取消",onClick:forceCloseModal},
        {label:"離開",primary:true,onClick:()=>{forceCloseModal(); leaveGame();}}
      ],
      showClose:false,
      lock:false
    });
  });

  submitBtn.addEventListener("click",submitAnswer);

  modalClose.addEventListener("click",()=>{if(modalLocked)return; forceCloseModal();});
  modalBackdrop.addEventListener("click",e=>{
    if(e.target!==modalBackdrop)return;
    if(modalLocked)return;
    forceCloseModal();
  });

  window.addEventListener("keydown",e=>{
    if(e.key==="Enter" && gameState.inGame && submitBtn.style.visibility!=="hidden"
       && !modalBackdrop.classList.contains("show")
       && !countdownOverlay.classList.contains("show")){
      submitAnswer();
    }
    if(e.key==="Escape" && modalBackdrop.classList.contains("show")){
      if(modalLocked)return;
      forceCloseModal();
    }
  });

  setSubmitVisible(false);
  nudgeScaleSoon();

  /* 一打開網頁就自動跳出遊戲說明（從第 1 頁開始） */
  setTimeout(()=>{
    if(!modalBackdrop.classList.contains("show")){
      openHelp(0);
    }
  },120);
})();
</script>
</body>
</html>
