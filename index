<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>排排看小遊戲</title>
  <style>
    @font-face{
      font-family:"BpmfZihiKaiStd";
      src:url("BpmfZihiKaiStd-Regular.ttf") format("truetype");
      font-display:swap;
    }

    :root{
      --bg:#f3f4fa;
      --text:#111827;
      --muted:#6b7280;
      --easy:#22c55e;
      --mid:#eab308;
      --hard:#f97316;
      --line:rgba(15,23,42,.12);
      --shadow:0 18px 45px rgba(15,23,42,.08);
      --radius:18px;

      --ui-scale:1;
      --pad-body:14px;

      --gamewrap-h:640px;
      --gamewrap-vh:70vh;

      --gameMain-pad:12px;
      --gameMain-gap:12px;

      --panel-pad:12px;
      --panel-gap:10px;

      --slots-gap:12px;
      --slot-h:104px;
      --slot-pad:6px;

      --submit-h:64px;
      --result-bottom-gap:22px;

      --home-title-top:46px;
      --home-title-bottom:42px;
      --home-diff-bottom:46px;
      --home-bottom-pad:12px;

      /* 說明視窗整體縮小，避免遮住標題與按鈕 */
      --help-modal-w:1120px;
      --help-body-maxh:72vh;
      --help-pane-minh:380px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:"BpmfZihiKaiStd", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Arial, "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
      background: radial-gradient(900px 700px at 20% 10%, #ffffff 0%, var(--bg) 55%);
      color:var(--text);
      min-height:100vh;
      display:flex; align-items:center; justify-content:center;
      padding:calc(var(--pad-body) * var(--ui-scale));
      overflow:hidden;
    }
    .app{
      width:min(980px,100%);
      border:1px solid var(--line);
      background: linear-gradient(180deg, #ffffff, #f9fafb);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .screen{display:none; padding:18px 16px 18px;}
    .screen.active{display:block;}

    /* HOME */
    .title{
      font-size:58px; font-weight:950; letter-spacing:1px;
      text-align:center;
      margin:calc(var(--home-title-top) * var(--ui-scale)) 0 calc(var(--home-title-bottom) * var(--ui-scale));
      color:#0f172a;
    }
    .difficultyRow{
      display:flex; justify-content:center; gap:14px; flex-wrap:wrap;
      margin:0 0 calc(var(--home-diff-bottom) * var(--ui-scale));
    }
    .diffBtn{
      min-width:190px;
      padding:15px 16px;
      border-radius:16px;
      background:#ffffff;
      color:#0f172a;
      border:3px solid transparent;
      cursor:pointer;
      font-weight:950;
      transition:.15s;
      font-size:18px;
      letter-spacing:.6px;
      box-shadow:0 6px 16px rgba(148,163,184,.18);
    }
    .diffBtn[data-diff="easy"]{border-color:var(--easy);}
    .diffBtn[data-diff="mid"]{border-color:var(--mid);}
    .diffBtn[data-diff="hard"]{border-color:var(--hard);}
    .diffBtn:hover{transform:translateY(-1px); box-shadow:0 10px 22px rgba(148,163,184,.24);}
    .diffBtn.selected{
      box-shadow:0 0 0 4px rgba(37,99,235,.16);
      transform:translateY(-1px);
    }
    .homeActions{
      display:flex; flex-direction:column; align-items:center;
      gap:10px;
      margin-bottom:calc(var(--home-bottom-pad) * var(--ui-scale));
    }
    .primaryBtn{
      width:min(520px,94%);
      padding:16px 18px;
      border-radius:16px;
      border:1px solid var(--line);
      background:#111827;
      color:#f9fafb;
      font-weight:950;
      letter-spacing:.8px;
      cursor:pointer;
      transition:.15s;
      font-size:18px;
      box-shadow:0 10px 25px rgba(15,23,42,.22);
    }
    .primaryBtn:disabled{
      opacity:.40;
      cursor:not-allowed;
      box-shadow:none;
      background:#9ca3af;
    }
    .primaryBtn:not(:disabled):hover{
      transform:translateY(-1px);
      background:#020617;
    }
    .secondaryBtn{
      width:min(520px,94%);
      padding:14px 18px;
      border-radius:16px;
      border:1px solid var(--line);
      background:#ffffff;
      color:var(--text);
      cursor:pointer;
      font-size:16px;
      font-weight:850;
      box-shadow:0 4px 10px rgba(148,163,184,.18);
    }
    .secondaryBtn:hover{background:#f3f4ff;}

    /* GAME TOP */
    .topbar{
      display:flex; align-items:center; justify-content:space-between;
      gap:10px;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:#f3f4ff;
    }
    .reqBox{
      flex:1;
      display:flex; align-items:center; justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      border:1px solid var(--line);
      border-radius:14px;
      background:#ffffff;
      min-height:56px;
      box-shadow:0 4px 10px rgba(148,163,184,.18);
    }
    .reqLeft{display:flex; flex-direction:column; gap:6px; min-width:0;}
    .reqText{
      font-size:22px; letter-spacing:.4px; font-weight:950;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
      color:#0f172a;
    }
    .reqMeta{
      font-size:14px; color:var(--muted);
      display:flex; gap:10px; flex-wrap:wrap;
    }
    .pill{
      border:1px solid var(--line);
      background:#eef2ff;
      padding:4px 10px;
      border-radius:999px;
      font-variant-numeric:tabular-nums;
      white-space:nowrap;
      font-weight:900;
    }
    .timer{
      font-variant-numeric:tabular-nums;
      font-weight:950;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid var(--line);
      background:#111827;
      color:#f9fafb;
      min-width:108px;
      text-align:center;
      font-size:16px;
      box-shadow:0 6px 18px rgba(15,23,42,.28);
    }
    .topActions{display:flex; gap:10px; align-items:center;}
    .iconBtn{
      border:1px solid var(--line);
      background:#ffffff;
      color:var(--text);
      padding:10px 12px;
      border-radius:12px;
      cursor:pointer;
      transition:.15s;
      white-space:nowrap;
      font-weight:900;
      font-size:15px;
      box-shadow:0 4px 12px rgba(148,163,184,.18);
    }
    .iconBtn:hover{
      transform:translateY(-1px);
      background:#e5edff;
    }

    /* GAME LAYOUT */
    .gameWrap{
      display:flex; flex-direction:column;
      height:min(calc(var(--gamewrap-h) * var(--ui-scale)), calc(var(--gamewrap-vh) * var(--ui-scale)));
    }
    .gameMain{
      flex:1;
      display:flex; flex-direction:column;
      gap:calc(var(--gameMain-gap) * var(--ui-scale));
      padding:calc(var(--gameMain-pad) * var(--ui-scale));
      min-height:0;
    }
    .upper,.lower{
      flex:1 1 50%;
      border-radius:var(--radius);
      border:1px solid var(--line);
      padding:calc(var(--panel-pad) * var(--ui-scale));
      display:flex; flex-direction:column;
      gap:calc(var(--panel-gap) * var(--ui-scale));
      min-height:0;
    }
    .upper{background:#f9fafb;}
    .lower{background:#f3f4ff;}

    .panelHeader{display:grid; grid-template-columns:1fr auto 1fr; align-items:center;}
    .panelTitle{
      text-align:center;
      font-weight:950;
      color:var(--muted);
      letter-spacing:.7px;
      font-size:16px;
    }
    .slots{
      display:grid;
      grid-template-columns:repeat(4, minmax(0, 1fr));
      gap:calc(var(--slots-gap) * var(--ui-scale));
      width:min(640px,100%);
      margin:0 auto;
      flex:0 0 auto;
    }
    .slot{
      height:calc(var(--slot-h) * var(--ui-scale));
      padding:calc(var(--slot-pad) * var(--ui-scale));
      border-radius:18px;
      border:2px dashed rgba(148,163,184,.55);
      background:#e5edff;
      display:flex; align-items:center; justify-content:center;
      transition:.12s;
    }
    .slot.over{
      outline:3px solid rgba(59,130,246,.55);
      outline-offset:2px;
      background:#dbeafe;
    }
    .slot.selectedTarget{
      outline:3px solid rgba(59,130,246,.65);
      outline-offset:2px;
      background:#dbeafe;
    }
    .card{
      width:100%; height:100%;
      border-radius:18px;
      border:1px solid rgba(148,163,184,.80);
      background:linear-gradient(180deg,#ffffff,#e5edff);
      display:flex; align-items:center; justify-content:center;
      font-size:calc(52px * var(--ui-scale));
      font-weight:980;
      letter-spacing:1px;
      cursor:grab;
      user-select:none;
      box-shadow:0 14px 28px rgba(15,23,42,.20);
      transition:.12s;
      color:#0f172a;
    }
    .card.selected{
      outline:4px solid rgba(59,130,246,.65);
      outline-offset:2px;
      transform:translateY(-1px);
      background:linear-gradient(180deg,#ffffff,#dbeafe);
    }

    .submitArea{
      height:calc(var(--submit-h) * var(--ui-scale));
      display:flex; justify-content:center; align-items:center;
      flex:0 0 calc(var(--submit-h) * var(--ui-scale));
    }
    .submitBtn{
      width:min(640px,100%);
      padding:14px 16px;
      border-radius:16px;
      border:1px solid var(--line);
      background:#111827;
      color:#f9fafb;
      font-weight:950;
      letter-spacing:.8px;
      cursor:pointer;
      transition:.15s;
      font-size:18px;
      box-shadow:0 10px 24px rgba(15,23,42,.30);
    }
    .submitBtn:hover{
      transform:translateY(-1px);
      background:#020617;
    }

    .toast{
      position:fixed;
      left:50%;
      bottom:16px;
      transform:translateX(-50%);
      background:#111827;
      border:1px solid rgba(15,23,42,.4);
      border-radius:14px;
      padding:10px 12px;
      box-shadow:0 16px 40px rgba(15,23,42,.45);
      color:#f9fafb;
      display:none;
      max-width:min(720px,92vw);
      font-size:14px;
      z-index:50;
    }
    .toast.show{display:block;}

    /* MODAL */
    .modalBackdrop{
      position:fixed; inset:0;
      background:rgba(15,23,42,.25);
      display:none;
      align-items:center; justify-content:center;
      padding:10px;
      z-index:40;
    }
    .modalBackdrop.show{display:flex;}
    .modal{
      width:min(var(--help-modal-w),98vw);
      border-radius:var(--radius);
      border:1px solid var(--line);
      background:#ffffff;
      box-shadow:0 24px 60px rgba(15,23,42,.20);
      overflow:hidden;
    }
    .modalHeader{
      padding:14px 14px;
      border-bottom:1px solid var(--line);
      display:flex; justify-content:space-between; align-items:center;
      gap:10px;
      background:#f3f4ff;
    }
    .modalHeader h3{
      margin:0;
      font-size:22px;
      letter-spacing:.4px;
      font-weight:950;
      color:#0f172a;
    }
    .modalClose{display:none;}
    .modalBody{
      padding:12px 12px 10px;
      color:var(--text);
      line-height:1.7;
      font-size:17px;
      max-height:var(--help-body-maxh);
      overflow:auto;
      background:#ffffff;
    }
    .modalActions{
      padding:12px 14px 14px;
      display:flex; gap:10px;
      justify-content:flex-end;
      border-top:1px solid var(--line);
      background:#f9fafb;
      flex-wrap:wrap;
      align-items:center;
    }
    .miniBtn{
      padding:10px 14px;
      border-radius:12px;
      border:1px solid var(--line);
      background:#ffffff;
      color:var(--text);
      cursor:pointer;
      font-size:15px;
      font-weight:900;
      box-shadow:0 4px 12px rgba(148,163,184,.18);
    }
    .miniBtn.primary{
      background:#111827;
      color:#f9fafb;
      font-weight:950;
      letter-spacing:.4px;
      box-shadow:0 8px 20px rgba(15,23,42,.35);
    }
    .miniBtn:disabled{
      opacity:.45;
      cursor:not-allowed;
      box-shadow:none;
    }

    table{
      width:100%;
      border-collapse:collapse;
      overflow:hidden;
      border-radius:14px;
      border:1px solid var(--line);
      font-size:14px;
      background:#ffffff;
    }
    th,td{
      padding:10px 10px;
      border-bottom:1px solid rgba(148,163,184,.18);
      text-align:left;
      vertical-align:top;
    }
    th{
      background:#f3f4ff;
      color:var(--muted);
      font-weight:950;
    }
    tr:last-child td{border-bottom:none;}
    .tag{
      display:inline-block;
      padding:4px 10px;
      border-radius:999px;
      border:1px solid rgba(148,163,184,.60);
      background:#eef2ff;
      font-size:12px;
      font-weight:950;
      letter-spacing:.3px;
      white-space:nowrap;
      color:#111827;
    }
    .tag.easy{border-color:rgba(34,197,94,.75); background:#dcfce7;}
    .tag.mid{border-color:rgba(234,179,8,.75); background:#fef9c3;}
    .tag.hard{border-color:rgba(249,115,22,.75); background:#ffedd5;}

    .resultBlock{margin-top:12px; padding-top:10px; border-top:1px solid rgba(148,163,184,.25);}
    .resultLabel{
      font-size:15px;
      color:var(--muted);
      font-weight:950;
      margin-bottom:8px;
      letter-spacing:.4px;
    }
    .cardRow{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}
    .miniCard{
      width:64px; height:76px;
      border-radius:16px;
      border:1px solid rgba(148,163,184,.80);
      background:linear-gradient(180deg,#ffffff,#e5edff);
      display:flex; align-items:center; justify-content:center;
      font-size:34px; font-weight:950;
      box-shadow:0 10px 22px rgba(15,23,42,.20);
      color:#0f172a;
    }

    /* countdown overlay */
    .countdownOverlay{
      position:fixed; inset:0;
      display:none; align-items:center; justify-content:center;
      background:rgba(15,23,42,.25);
      z-index:60;
    }
    .countdownOverlay.show{display:flex;}
    .countdownBox{
      width:min(520px,92vw);
      border-radius:var(--radius);
      border:1px solid var(--line);
      background:#ffffff;
      box-shadow:0 24px 60px rgba(15,23,42,.25);
      padding:24px 18px;
      text-align:center;
    }
    .countdownTitle{
      font-size:18px;
      color:var(--muted);
      font-weight:950;
      letter-spacing:.6px;
    }
    .countdownNum{
      font-size:72px;
      font-weight:980;
      letter-spacing:2px;
      margin-top:10px;
      font-variant-numeric:tabular-nums;
      color:#0f172a;
    }

    /* HELP layout */
    .helpGrid{
      display:grid;
      grid-template-columns:.92fr 1.08fr;
      gap:14px;
      align-items:stretch;
    }
    @media (max-width:980px){
      .helpGrid{grid-template-columns:1fr;}
    }
    .helpPane{
      border:1px solid var(--line);
      background:#f9fafb;
      border-radius:14px;
      padding:14px;
      min-height:var(--help-pane-minh);
      display:flex;
      flex-direction:column;
      justify-content:flex-start;
      overflow:hidden;
    }
    .helpPaneScroll{
      overflow:auto;
      padding-right:4px;
      max-height:var(--help-pane-minh);
    }
    .helpCard{
      border:1px solid rgba(148,163,184,.4);
      background:#ffffff;
      border-radius:14px;
      padding:12px 12px;
      margin:10px 0;
      box-shadow:0 4px 10px rgba(148,163,184,.18);
    }
    .helpTitle{
      font-weight:950;
      letter-spacing:.4px;
      margin:0 0 6px;
      font-size:19px;
      color:#0f172a;
    }
    .helpText{
      color:rgba(15,23,42,.88);
      margin:0;
      font-size:17px;
      line-height:1.75;
    }
    .noteLine{
      display:flex; gap:10px; align-items:flex-start;
      margin:8px 0;
    }
    .noteNum{
      display:inline-flex; align-items:center; justify-content:center;
      width:26px; height:26px;
      border-radius:999px;
      border:1px solid rgba(148,163,184,.8);
      background:#e5edff;
      font-weight:950;
      font-size:13px;
      flex:0 0 auto;
      margin-top:2px;
      box-shadow:0 6px 16px rgba(148,163,184,.4);
      color:#0f172a;
    }
    .kbd{
      display:inline-block;
      padding:2px 8px;
      border-radius:999px;
      border:1px solid rgba(148,163,184,.7);
      background:#e5edff;
      font-variant-numeric:tabular-nums;
      font-size:13px;
      font-weight:900;
      margin:0 2px;
      color:#111827;
      white-space:nowrap;
    }
    .mockTitle{
      font-size:14px;
      color:rgba(55,65,81,.90);
      font-weight:900;
      letter-spacing:.4px;
      margin:0 0 10px;
    }
    .svgWrap{
      border-radius:12px;
      overflow:hidden;
      border:1px solid rgba(148,163,184,.5);
      background:#e5edff;
      flex:1;
      display:flex;
      align-items:stretch;
      justify-content:center;
    }
    .svgWrap svg{width:100%; height:100%; display:block;}
  </style>
</head>

<body>
  <div class="app">
    <!-- HOME -->
    <div id="home" class="screen active">
      <div class="title">排排看小遊戲</div>

      <div class="difficultyRow">
        <button class="diffBtn" data-diff="easy">簡單</button>
        <button class="diffBtn" data-diff="mid">中等</button>
        <button class="diffBtn" data-diff="hard">困難</button>
      </div>

      <div class="homeActions">
        <button id="startGameBtn" class="primaryBtn" disabled>開始遊戲</button>
        <button id="helpBtnHome" class="secondaryBtn">遊戲說明</button>
        <button id="recordsBtnHome" class="secondaryBtn">遊戲紀錄</button>
      </div>
    </div>

    <!-- GAME -->
    <div id="game" class="screen">
      <div class="topbar">
        <div class="reqBox">
          <div class="reqLeft">
            <div class="reqText" id="reqText">—</div>
            <div class="reqMeta">
              <span class="pill" id="roundPill">第 1 回合 / 共 3 回合</span>
              <span class="pill" id="correctPill">已答對 0 題</span>
              <span class="pill" id="diffPill">難度：—</span>
            </div>
          </div>
          <div class="timer" id="timer">—秒</div>
        </div>

        <div class="topActions">
          <button id="recordsBtnGame" class="iconBtn">遊戲紀錄</button>
          <button id="helpBtnGame" class="iconBtn">遊戲說明</button>
          <button id="leaveBtnGame" class="iconBtn">離開遊戲</button>
        </div>
      </div>

      <div class="gameWrap">
        <div class="gameMain">
          <div class="upper">
            <div class="panelHeader"><div></div><div class="panelTitle">作答欄</div><div></div></div>
            <div class="slots" id="answerSlots"></div>
          </div>

          <div class="lower">
            <div class="panelHeader"><div></div><div class="panelTitle">本回合使用的數字牌</div><div></div></div>
            <div class="slots" id="deckSlots"></div>
            <div class="submitArea" id="submitArea">
              <button id="submitBtn" class="submitBtn">送出答案</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL -->
  <div id="modalBackdrop" class="modalBackdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true">
      <div class="modalHeader">
        <h3 id="modalTitle">提示</h3>
        <button id="modalClose" class="modalClose">關閉</button>
      </div>
      <div class="modalBody" id="modalBody"></div>
      <div class="modalActions" id="modalActions"></div>
    </div>
  </div>

  <!-- 3-second countdown overlay -->
  <div id="countdownOverlay" class="countdownOverlay" aria-hidden="true">
    <div class="countdownBox">
      <div class="countdownTitle">遊戲即將開始</div>
      <div class="countdownNum" id="countdownNum">3</div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

<script>
(() => {
  const DIFF = {
    easy:{name:"簡單",limits:[150,120,90]},
    mid:{name:"中等",limits:[90,60,30]},
    hard:{name:"困難",limits:[20,20,20]}
  };

  let selectedDiff = null;

  let gameState = {
    inGame:false,
    diffKey:null,
    roundIndex:0,
    roundGoal:null,
    digits:[],
    limitSec:0,
    startTs:0,
    timerId:null,
    remainingMs:0,
    perRoundTimes:[],
    lastAnswerDigits:null
  };

  let selectedCardEl = null;
  let modalLocked = false;
  let skipRecordThisGame = false;
  let timeoutEndState = null;

  let helpPage = 0;

  const homeEl = document.getElementById("home");
  const gameEl = document.getElementById("game");

  const diffBtns = [...document.querySelectorAll(".diffBtn")];
  const startGameBtn = document.getElementById("startGameBtn");
  const helpBtnHome = document.getElementById("helpBtnHome");
  const helpBtnGame = document.getElementById("helpBtnGame");
  const recordsBtnHome = document.getElementById("recordsBtnHome");
  const recordsBtnGame = document.getElementById("recordsBtnGame");
  const leaveBtnGame = document.getElementById("leaveBtnGame");

  const reqTextEl = document.getElementById("reqText");
  const timerEl = document.getElementById("timer");
  const roundPillEl = document.getElementById("roundPill");
  const correctPillEl = document.getElementById("correctPill");
  const diffPillEl = document.getElementById("diffPill");

  const answerSlotsEl = document.getElementById("answerSlots");
  const deckSlotsEl = document.getElementById("deckSlots");
  const submitBtn = document.getElementById("submitBtn");

  const modalBackdrop = document.getElementById("modalBackdrop");
  const modalTitle = document.getElementById("modalTitle");
  const modalBody = document.getElementById("modalBody");
  const modalActions = document.getElementById("modalActions");
