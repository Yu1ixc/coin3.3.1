  function randomUniqueDigits(count=4){
    const pool=[...Array(10)].map((_,i)=>i);
    for(let i=pool.length-1;i>0;i--){
      const j=Math.floor(Math.random()*(i+1));
      [pool[i],pool[j]]=[pool[j],pool[i]];
    }
    return pool.slice(0,count);
  }
  function computeAnswer(goal,digits){
    const sorted=[...digits].sort((a,b)=>goal==="max"?b-a:a-b);
    return sorted.join("");
  }
  function computeAnswerDigits(goal,digits){
    return [...digits].sort((a,b)=>goal==="max"?b-a:a-b);
  }
