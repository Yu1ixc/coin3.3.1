  /* ==== Drag / Drop ==== */
  function makeSlot(){
    const slot=document.createElement("div");
    slot.className="slot";

    slot.addEventListener("click",()=>{
      if(modalBackdrop.classList.contains("show"))return;
      if(countdownOverlay.classList.contains("show"))return;
      if(!selectedCardEl)return;
      const fromSlot=selectedCardEl.parentElement?.classList.contains("slot")?selectedCardEl.parentElement:null;
      if(!fromSlot)return;
      if(fromSlot===slot){clearTapSelection(); return;}

      swapOrMoveCard(fromSlot,slot,selectedCardEl);
      clearTapSelection();
      updateSubmitVisibility();
    });

    slot.addEventListener("dragover",e=>{e.preventDefault(); slot.classList.add("over");});
    slot.addEventListener("dragleave",()=>slot.classList.remove("over"));
    slot.addEventListener("drop",e=>{
      e.preventDefault();
      slot.classList.remove("over");
      const draggedId=e.dataTransfer.getData("text/plain");
      const draggedCard=document.getElementById(draggedId);
      if(!draggedCard)return;
      const fromSlot=draggedCard.parentElement?.classList.contains("slot")?draggedCard.parentElement:null;
      if(!fromSlot)return;
      if(fromSlot===slot)return;
      swapOrMoveCard(fromSlot,slot,draggedCard);
      updateSubmitVisibility();
    });

    return slot;
  }

  function makeCard(digit,id){
    const card=document.createElement("div");
    card.className="card";
    card.textContent=String(digit);
    card.id=id;
    card.draggable=true;

    card.addEventListener("dragstart",e=>{
      e.dataTransfer.setData("text/plain",card.id);
      e.dataTransfer.effectAllowed="move";
      clearTapSelection();
    });

    card.addEventListener("click",e=>{
      e.stopPropagation();
      if(modalBackdrop.classList.contains("show"))return;
      if(countdownOverlay.classList.contains("show"))return;

      if(selectedCardEl===card){
        clearTapSelection();
        return;
      }
      clearTapSelection();
      selectedCardEl=card;
      card.classList.add("selected");
      [...document.querySelectorAll(".slot")].forEach(s=>s.classList.add("selectedTarget"));
    });

    return card;
  }

  function swapOrMoveCard(fromSlot,toSlot,movingCard){
    const targetCard=toSlot.querySelector(".card");
    if(targetCard){fromSlot.appendChild(targetCard);}
    toSlot.appendChild(movingCard);
  }

  function renderBoard(digits){
    clearTapSelection();
    answerSlotsEl.innerHTML="";
    deckSlotsEl.innerHTML="";

    for(let i=0;i<4;i++){
      answerSlotsEl.appendChild(makeSlot());
      deckSlotsEl.appendChild(makeSlot());
    }
    digits.forEach((d,i)=>{
      const card=makeCard(d,`card_${Date.now()}_${i}`);
      deckSlotsEl.children[i].appendChild(card);
    });

    updateSubmitVisibility();
    nudgeScaleSoon();
  }

  function setSubmitVisible(visible){
    submitBtn.style.visibility=visible?"visible":"hidden";
    submitBtn.style.pointerEvents=visible?"auto":"none";
  }
  function updateSubmitVisibility(){
    const deckHasCard=[...deckSlotsEl.querySelectorAll(".slot")].some(s=>s.querySelector(".card"));
    setSubmitVisible(!deckHasCard);
  }

  /* 讀取作答欄答案，同時記錄「你的答案」的每一位數字 */
  function readAnswerString(){
    const slots=[...answerSlotsEl.querySelectorAll(".slot")];
    const cards=slots.map(s=>s.querySelector(".card"));
    if(cards.some(c=>!c))return null;
    const digits=cards.map(c=>Number(c.textContent));
    gameState.lastAnswerDigits=digits;
    return digits.join("");
  }

  /* ==== Game flow ==== */
  function stopTimer(){
    if(gameState.timerId){
      clearInterval(gameState.timerId);
      gameState.timerId=null;
    }
  }
  function setTopbarText(){
    const goalText=gameState.roundGoal==="max"?"請排出最大的數":"請排出最小的數";
    reqTextEl.textContent=goalText;
    timerEl.textContent=secondsText(gameState.remainingMs);
    roundPillEl.textContent=`第 ${gameState.roundIndex+1} 回合 / 共 3 回合`;
    correctPillEl.textContent=`已答對 ${gameState.perRoundTimes.length} 題`;
    diffPillEl.textContent=`難度：${DIFF[gameState.diffKey]?.name ?? "—"}`;
  }
  function startRoundCountdownTimer(){
    stopTimer();
    gameState.startTs=performance.now();
    gameState.remainingMs=gameState.limitSec*1000;
    setTopbarText();

    gameState.timerId=setInterval(()=>{
      const elapsed=performance.now()-gameState.startTs;
      const left=Math.max(0,gameState.limitSec*1000-elapsed);
      gameState.remainingMs=left;
      timerEl.textContent=secondsText(left);
      if(left<=0){
        stopTimer();
        endGame(false,"timeout","時間到，這一局遊戲結束。");
      }
    },120);
  }
  function setupRound(){
    clearTapSelection();
    gameState.digits=randomUniqueDigits(4);
    gameState.roundGoal=Math.random()<0.5?"max":"min";
    gameState.limitSec=DIFF[gameState.diffKey].limits[gameState.roundIndex];
    gameState.lastAnswerDigits=null;
    renderBoard(gameState.digits);
    gameState.remainingMs=gameState.limitSec*1000;
    setTopbarText();
  }
  function runStartCountdown3s(){
    return new Promise(resolve=>{
      let n=3;
      countdownNumEl.textContent=String(n);
      countdownOverlay.classList.add("show");
      countdownOverlay.setAttribute("aria-hidden","false");
      nudgeScaleSoon();
      const tick=()=>{
        n-=1;
        if(n<=0){
          countdownOverlay.classList.remove("show");
          countdownOverlay.setAttribute("aria-hidden","true");
          nudgeScaleSoon();
          resolve();
          return;
        }
        countdownNumEl.textContent=String(n);
        setTimeout(tick,1000);
      };
      setTimeout(tick,1000);
    });
  }
  async function startGame(){
    skipRecordThisGame=false;
    gameState.inGame=true;
    gameState.roundIndex=0;
    gameState.perRoundTimes=[];
    gameState.lastAnswerDigits=null;
    switchScreen(true);
    timerEl.textContent="—秒";
    reqTextEl.textContent="—";
    setupRound();
    await runStartCountdown3s();
    if(!gameState.inGame)return;
    startRoundCountdownTimer();
  }

